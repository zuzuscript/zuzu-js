#!/usr/bin/env node
'use strict';

const { runElectronMain } = require( '../lib/electron/main' );

runElectronMain( process.argv.slice( 2 ) ).then(
	(exitCode) => {
		process.exitCode = exitCode;
	},
	(err) => {
		process.stderr.write( `${err && err.stack ? err.stack : String( err )}\n` );
		process.exitCode = 1;
	},
);
